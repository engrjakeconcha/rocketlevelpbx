generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AuditActionType {
  CREATED
  UPDATED
  DELETED
  ENABLED
  DISABLED
  REORDERED
  SYNCED
  RETRIED
  LOGIN
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  IMPERSONATED
}

enum OverrideMode {
  FORCE_OPEN
  FORCE_CLOSED
  VACATION
  AFTER_HOURS_FORWARDING
}

enum CoverageMemberType {
  USER
  EXTERNAL_NUMBER
}

enum CoverageMemberStatus {
  ACTIVE
  INACTIVE
  TEMPORARILY_UNAVAILABLE
}

enum MappingType {
  DOMAIN
  SCHEDULE_TEMPLATE
  COVERAGE_GROUP
  COVERAGE_MEMBER
  OVERRIDE
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String
  passwordHash           String
  role                   UserRole                @default(CUSTOMER)
  isActive               Boolean                 @default(true)
  resetToken             String?
  resetTokenExpiresAt    DateTime?
  memberships            Membership[]
  sessions               Session[]
  auditLogs              AuditLog[]              @relation("AuditActor")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Domain {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  description            String
  timezone               String
  inboundNumber          String?
  policyJson             Json
  isActive               Boolean                 @default(true)
  memberships            Membership[]
  scheduleTemplates      ScheduleTemplate[]
  coverageGroups         CoverageGroup[]
  allowedNumberPool      AllowedNumberPool[]
  backendMappings        BackendMapping[]
  auditLogs              AuditLog[]
  syncJobs               SyncJob[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Membership {
  id                     String                  @id @default(cuid())
  userId                 String
  domainId               String
  isPrimary              Boolean                 @default(true)
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())

  @@unique([userId, domainId])
}

model ScheduleTemplate {
  id                     String                  @id @default(cuid())
  domainId               String
  name                   String
  timezone               String
  isDefault              Boolean                 @default(true)
  syncStatus             SyncStatus              @default(PENDING)
  lastSyncedAt           DateTime?
  lastSyncMessage        String?
  weeklyRules            WeeklyScheduleRule[]
  holidayClosures        HolidayClosure[]
  overrides              ScheduleOverride[]
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model WeeklyScheduleRule {
  id                     String                  @id @default(cuid())
  scheduleTemplateId     String
  dayOfWeek              Int
  isOpen                 Boolean                 @default(true)
  startTime              String?
  endTime                String?
  scheduleTemplate       ScheduleTemplate        @relation(fields: [scheduleTemplateId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model HolidayClosure {
  id                     String                  @id @default(cuid())
  scheduleTemplateId     String
  name                   String
  startsAt               DateTime
  endsAt                 DateTime
  scheduleTemplate       ScheduleTemplate        @relation(fields: [scheduleTemplateId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model ScheduleOverride {
  id                     String                  @id @default(cuid())
  scheduleTemplateId     String
  mode                   OverrideMode
  label                  String
  startsAt               DateTime
  endsAt                 DateTime
  targetNumber           String?
  enabled                Boolean                 @default(true)
  syncStatus             SyncStatus              @default(PENDING)
  lastSyncedAt           DateTime?
  scheduleTemplate       ScheduleTemplate        @relation(fields: [scheduleTemplateId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model CoverageGroup {
  id                     String                  @id @default(cuid())
  domainId               String
  name                   String
  maxMembers             Int                     @default(10)
  allowCustomerAdditions Boolean                 @default(false)
  allowExternalNumbers   Boolean                 @default(false)
  syncStatus             SyncStatus              @default(PENDING)
  lastSyncedAt           DateTime?
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  members                CoverageMember[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model CoverageMember {
  id                     String                  @id @default(cuid())
  coverageGroupId        String
  displayLabel           String
  memberType             CoverageMemberType
  destinationNumber      String
  sortOrder              Int
  enabled                Boolean                 @default(true)
  temporaryStatus        CoverageMemberStatus    @default(ACTIVE)
  coverageGroup          CoverageGroup           @relation(fields: [coverageGroupId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model AllowedNumberPool {
  id                     String                  @id @default(cuid())
  domainId               String
  phoneNumber            String
  label                  String?
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
}

model BackendMapping {
  id                     String                  @id @default(cuid())
  domainId               String
  mappingType            MappingType
  internalKey            String
  externalRef            String
  metadataJson           Json?
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model AuditLog {
  id                     String                  @id @default(cuid())
  actorId                String?
  domainId               String
  actorRole              UserRole
  actionType             AuditActionType
  objectType             String
  objectId               String
  beforeJson             Json?
  afterJson              Json?
  syncStatus             SyncStatus              @default(PENDING)
  requestId              String
  message                String?
  actor                  User?                   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())
}

model SyncJob {
  id                     String                  @id @default(cuid())
  domainId               String
  resourceType           String
  resourceId             String
  status                 SyncStatus              @default(PENDING)
  operation              String
  lastError              String?
  retryCount             Int                     @default(0)
  requestedByUserId      String?
  requestedAt            DateTime                @default(now())
  completedAt            DateTime?
  domain                 Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model Session {
  id                     String                  @id @default(cuid())
  sessionToken           String                  @unique
  userId                 String
  expires                DateTime
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier             String
  token                  String                  @unique
  expires                DateTime

  @@unique([identifier, token])
}
